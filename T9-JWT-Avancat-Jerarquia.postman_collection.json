{
  "info": {
    "name": "T9 - JWT Avançat + Jerarquia de Rols",
    "description": "Col·lecció completa amb les 51 proves del projecte T9",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 1. AUTENTICACIÓ",
      "item": [
        {
          "name": "1.1 Registre d'Usuari",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"joan@example.com\", \"password\": \"Password123!\", \"firstName\": \"Joan\", \"lastName\": \"Garcia\"}"},
            "url": {"raw": "http://localhost:3000/api/auth/register", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "1.2 Login Correcte",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"admin@system.com\", \"password\": \"Admin123!\"}"},
            "url": {"raw": "http://localhost:3000/api/auth/login", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "1.3 Login Incorrecte",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"admin@system.com\", \"password\": \"wrongpass\"}"},
            "url": {"raw": "http://localhost:3000/api/auth/login", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "1.4 Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"refreshToken\": \"{{refreshToken}}\"}"},
            "url": {"raw": "http://localhost:3000/api/auth/refresh", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "refresh"]}
          }
        },
        {
          "name": "1.5 Logout",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"refreshToken\": \"{{refreshToken}}\"}"},
            "url": {"raw": "http://localhost:3000/api/auth/logout", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "logout"]}
          }
        },
        {
          "name": "1.6 Forgot Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"admin@system.com\"}"},
            "url": {"raw": "http://localhost:3000/api/auth/forgot-password", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "forgot-password"]}
          }
        }
      ]
    },
    {
      "name": "👥 2. USUARIS",
      "item": [
        {
          "name": "2.1 Llistar Usuaris",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/users", "host": ["localhost"], "port": "3000", "path": ["api", "users"]}
          }
        },
        {
          "name": "2.2 Obtenir Usuari per ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/users/{{userId}}", "host": ["localhost"], "port": "3000", "path": ["api", "users", "{{userId}}"]}
          }
        },
        {
          "name": "2.3 Obtenir Permisos Usuari",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/users/{{userId}}/permissions", "host": ["localhost"], "port": "3000", "path": ["api", "users", "{{userId}}", "permissions"]}
          }
        }
      ]
    },
    {
      "name": "🎭 3. ROLS",
      "item": [
        {
          "name": "3.1 Llistar Rols",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/roles", "host": ["localhost"], "port": "3000", "path": ["api", "roles"]}
          }
        },
        {
          "name": "3.2 Veure Jerarquia",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/roles/{{roleId}}/hierarchy", "host": ["localhost"], "port": "3000", "path": ["api", "roles", "{{roleId}}", "hierarchy"]}
          }
        },
        {
          "name": "3.3 Crear Rol",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"name\": \"editor\", \"level\": 2, \"description\": \"Editor de tasques\"}"},
            "url": {"raw": "http://localhost:3000/api/roles", "host": ["localhost"], "port": "3000", "path": ["api", "roles"]}
          }
        }
      ]
    },
    {
      "name": "🔑 4. PERMISOS",
      "item": [
        {
          "name": "4.1 Llistar Permisos",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/permissions", "host": ["localhost"], "port": "3000", "path": ["api", "permissions"]}
          }
        },
        {
          "name": "4.2 Crear Permís",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"name\": \"tasks:delete\", \"description\": \"Esborrar tasques\", \"category\": \"tasks\"}"},
            "url": {"raw": "http://localhost:3000/api/permissions", "host": ["localhost"], "port": "3000", "path": ["api", "permissions"]}
          }
        }
      ]
    },
    {
      "name": "🤝 5. DELEGACIÓ",
      "item": [
        {
          "name": "5.1 Crear Delegació",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"toUserId\": \"{{userId}}\", \"permission\": \"tasks:read\", \"reason\": \"Test\", \"daysValid\": 5}"},
            "url": {"raw": "http://localhost:3000/api/delegations", "host": ["localhost"], "port": "3000", "path": ["api", "delegations"]}
          }
        },
        {
          "name": "5.2 Llistar Delegacions",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/delegations", "host": ["localhost"], "port": "3000", "path": ["api", "delegations"]}
          }
        }
      ]
    },
    {
      "name": "📊 6. AUDITORIA",
      "item": [
        {
          "name": "6.1 Obtenir Logs",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/audit/logs", "host": ["localhost"], "port": "3000", "path": ["api", "audit", "logs"]}
          }
        },
        {
          "name": "6.2 Estadístiques",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/audit/stats", "host": ["localhost"], "port": "3000", "path": ["api", "audit", "stats"]}
          }
        },
        {
          "name": "6.3 Exportar CSV",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/audit/export?format=csv", "host": ["localhost"], "port": "3000", "path": ["api", "audit", "export"], "query": [{"key": "format", "value": "csv"}]}
          }
        }
      ]
    },
    {
      "name": "📋 7. TASQUES",
      "item": [
        {
          "name": "7.1 Crear Tasca",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"title\": \"Tasca test\", \"description\": \"Descripció\", \"status\": \"pending\"}"},
            "url": {"raw": "http://localhost:3000/api/tasks", "host": ["localhost"], "port": "3000", "path": ["api", "tasks"]}
          }
        },
        {
          "name": "7.2 Llistar Tasques",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "http://localhost:3000/api/tasks", "host": ["localhost"], "port": "3000", "path": ["api", "tasks"]}
          }
        },
        {
          "name": "7.3 Actualitzar Tasca",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"title\": \"Tasca actualitzada\", \"status\": \"completed\"}"},
            "url": {"raw": "http://localhost:3000/api/tasks/{{taskId}}", "host": ["localhost"], "port": "3000", "path": ["api", "tasks", "{{taskId}}"]}
          }
        }
      ]
    }
  ],
