          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}], "body": {"mode": "raw", "raw": "{\"name\": \"invalid\", \"level\": 1, \"parentRole\": \"{{roleId}}\", \"description\": \"Test\"}"}, "url": "http://localhost:3000/api/roles"},
          "event": [{"listen": "test", "script": {"exec": ["pm.test(\"Status 400\", () => pm.response.to.have.status(400));"]}}]
