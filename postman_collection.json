{
  "info": {
    "name": "T9 - JWT Avançat + Jerarquia de Rols (51 proves)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. AUTENTICACIÓ (7 proves)",
      "item": [
        {
          "name": "1.1 Registre d'Usuari",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"joan_{{$timestamp}}@example.com\", \"password\": \"Password123!\", \"firstName\": \"Joan\", \"lastName\": \"Garcia\"}"},
            "url": "http://localhost:3000/api/auth/register"
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test(\"Status 201\", () => pm.response.to.have.status(201));"]}}]
        },
        {
          "name": "1.2 Login Correcte",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"admin@system.com\", \"password\": \"Admin123!\"}"},
            "url": "http://localhost:3000/api/auth/login"
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "if(json.data && json.data.accessToken) {",
            "  pm.collectionVariables.set(\"accessToken\", json.data.accessToken);",
            "  pm.collectionVariables.set(\"refreshToken\", json.data.refreshToken);",
            "  pm.collectionVariables.set(\"userId\", json.data.user.id);",
            "}"
          ]}}]
        },
        {
          "name": "1.3 Login Incorrecte",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"admin@system.com\", \"password\": \"wrong\"}"},
            "url": "http://localhost:3000/api/auth/login"
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test(\"Status 401\", () => pm.response.to.have.status(401));"]}}]
        },
        {
          "name": "1.4 Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"refreshToken\": \"{{refreshToken}}\"}"},
            "url": "http://localhost:3000/api/auth/refresh"
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "if(json.accessToken) pm.collectionVariables.set(\"accessToken\", json.accessToken);"
          ]}}]
        },
        {
          "name": "1.5 Logout",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"refreshToken\": \"{{refreshToken}}\"}"},
            "url": "http://localhost:3000/api/auth/logout"
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "1.6 Forgot Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\": \"admin@system.com\"}"},
            "url": "http://localhost:3000/api/auth/forgot-password"
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "1.7 Reset Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"newPassword\": \"NovaPassword123!\"}"},
            "url": "http://localhost:3000/api/auth/reset-password/{{resetToken}}"
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test(\"Status 200\", () => pm.response.to.have.status(200));"]}}]
        }
      ]
    },
